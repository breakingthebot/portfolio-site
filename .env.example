# .env.example
# Optional overrides. None are required for standard defaults.

# Override the URL the Projects page fetches highlighted builds from.
# Defaults to the live 286-builds index if unset.
VITE_BUILDS_DATA_URL=

# Formspree endpoint for the Contact page's form (e.g. https://formspree.io/f/xxxxxxxx).
# Sign up free at https://formspree.io, create a form, and paste its endpoint here.
# Until this is set, the Contact page shows a "not configured" notice and falls
# back to the mailto: link instead of a broken-looking form.
VITE_CONTACT_FORM_ENDPOINT=
